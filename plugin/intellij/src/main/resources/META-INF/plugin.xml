<idea-plugin>
    <id>dev.cempw.intellij</id>
    <name>cem — multi-AI orchestrator</name>
    <vendor email="hi@cem.pw" url="https://cem.pw">cem.pw</vendor>

    <description><![CDATA[
        <p>Run the <a href="https://github.com/muslu/cem">cem</a> CLI from inside PyCharm / IntelliJ IDEA / GoLand / WebStorm.</p>

        <p><b>cem</b> is a single command that drives multiple AI CLIs
        (Claude · Antigravity · Codex · Cursor). One AI thinks, another
        writes; in <code>pair</code> mode the thinker's analysis is fed
        to the writer.</p>

        <p>This plugin adds three actions to the editor's context menu and
        <b>Tools → cem</b>:</p>
        <ul>
            <li><b>cem: think on selection</b> (default <code>Ctrl+Alt+I</code>)</li>
            <li><b>cem: write on selection</b> (default <code>Ctrl+Alt+W</code>)</li>
            <li><b>cem: pair on selection</b> (default <code>Ctrl+Alt+P</code>)</li>
        </ul>

        <p>The selected text is piped to <code>cem</code> as the prompt.
        Output streams into a dedicated tool window.</p>

        <p>Configuration: <b>Settings → Tools → cem</b> sets the path to
        the <code>cem</code> binary (default: <code>cem</code> on PATH).</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool window for cem output. canCloseContents="true" ile her tab'ın
             X butonu görünür hale gelir (kodda ContentManager.canCloseContents
             property'sini set etmek yeterli değil 2024.x sürümlerinde). -->
        <toolWindow id="cem"
                    anchor="bottom"
                    canCloseContents="true"
                    icon="AllIcons.Toolwindows.ToolWindowMessages"
                    factoryClass="dev.cempw.intellij.CemToolWindowFactory"/>

        <!-- Settings page -->
        <applicationConfigurable parentId="tools"
                                 id="dev.cempw.intellij.settings"
                                 displayName="cem"
                                 instance="dev.cempw.intellij.CemSettingsConfigurable"/>

        <!-- Persistent settings -->
        <applicationService serviceImplementation="dev.cempw.intellij.CemSettings"/>
    </extensions>

    <actions>
        <!-- Editor & Tools menüsü: kod / seçim üzerine aksiyonlar -->
        <group id="dev.cempw.intellij.MenuGroup"
               text="cem — Compose · Execute · Multiplex"
               description="One command, many AIs"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>

            <action id="dev.cempw.intellij.ThinkAction"
                    class="dev.cempw.intellij.CemAction$Think"
                    text="cem: think on selection"
                    description="Send selected text to the cem thinker. Empty selection → input dialog.">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt I"/>
            </action>

            <action id="dev.cempw.intellij.WriteAction"
                    class="dev.cempw.intellij.CemAction$Write"
                    text="cem: write on selection"
                    description="Send selected text to the cem writer. Empty selection → input dialog.">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt W"/>
            </action>

            <action id="dev.cempw.intellij.PairAction"
                    class="dev.cempw.intellij.CemAction$Pair"
                    text="cem: pair on selection"
                    description="Run cem pair mode (thinker → writer). Empty selection → input dialog.">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt P"/>
            </action>

            <separator/>

            <action id="dev.cempw.intellij.AskAction"
                    class="dev.cempw.intellij.CemAskAction"
                    text="cem: ask freely…"
                    description="Open a prompt dialog and run cem -p (no editor required).">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt A"/>
            </action>
        </group>

        <!-- Project tree (dosya/dizin sağ-tık) → 'cem' submenüsü -->
        <group id="dev.cempw.intellij.FileMenuGroup"
               text="cem — multi-AI"
               description="cem actions on the selected file(s)"
               popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

            <action id="dev.cempw.intellij.FileReview"
                    class="dev.cempw.intellij.CemFileAction$Review"
                    text="cem: review file…"
                    description="Quality / bug / improvement review of the selected file(s)"/>

            <action id="dev.cempw.intellij.FileFix"
                    class="dev.cempw.intellij.CemFileAction$FixErrors"
                    text="cem: fix errors…"
                    description="Find and fix bugs in the selected file(s)"/>

            <action id="dev.cempw.intellij.FileExplain"
                    class="dev.cempw.intellij.CemFileAction$Explain"
                    text="cem: explain…"
                    description="Plain-language explanation of what the file does"/>

            <separator/>

            <action id="dev.cempw.intellij.FileAsk"
                    class="dev.cempw.intellij.CemFileAction$Ask"
                    text="cem: ask about file…"
                    description="Custom prompt + file content as context"/>
        </group>
    </actions>
</idea-plugin>
